{
  "name": "hybx-dev",
  "displayName": "HybX Development System",
  "description": "Hybrid RobotiX — HybX Development System integration for VSCode",
  "version": "0.2.0",
  "publisher": "hybridrobotix",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/hybotix/HybX-Development-System.git"
  },
  "homepage": "https://github.com/hybotix/HybX-Development-System",
  "bugs": {
    "url": "https://github.com/hybotix/HybX-Development-System/issues"
  },
  "contributes": {
    "configuration": {
      "title": "HybX Development System",
      "properties": {
        "hybxDev.sshHost": {
          "type": "string",
          "default": "arduino@uno-q.local",
          "description": "SSH connection string for the board (user@host)"
        },
        "hybxDev.appsPath": {
          "type": "string",
          "default": "~/Arduino/UNO-Q",
          "description": "Path to the Arduino apps directory on the board"
        },
        "hybxDev.sshKeyPath": {
          "type": "string",
          "default": "",
          "description": "Path to SSH private key (leave empty to use password auth)"
        }
      }
    },
    "commands": [
      {
        "command": "hybxDev.connect",
        "title": "HybX: Connect"
      },
      {
        "command": "hybxDev.clean",
        "title": "HybX: Clean (stop + compile + flash + start)"
      },
      {
        "command": "hybxDev.start",
        "title": "HybX: Start App"
      },
      {
        "command": "hybxDev.stop",
        "title": "HybX: Stop App"
      },
      {
        "command": "hybxDev.restart",
        "title": "HybX: Restart App"
      },
      {
        "command": "hybxDev.mon",
        "title": "HybX: Monitor App Output (mon)"
      },
      {
        "command": "hybxDev.build",
        "title": "HybX: Build App (compile + flash only)"
      },
      {
        "command": "hybxDev.libs",
        "title": "HybX: Library Manager (libs)"
      },
      {
        "command": "hybxDev.listApps",
        "title": "HybX: List Apps"
      },
      {
        "command": "hybxDev.update",
        "title": "HybX: Update System (update)"
      },
      {
        "command": "hybxDev.clearPassword",
        "title": "HybX: Clear Stored SSH Password"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  }
}
